// Copy this file to `secrets.h` and fill in your values. secrets.h is
// gitignored. The PG_SERVER_HOST is the local IP of the PC running the
// Palm Guard backend - find it with `ipconfig` (Windows) or `ifconfig` /
// `ip addr` (macOS / Linux). The Vite dev terminal also prints the IP it
// bound to (e.g. http://192.168.1.42:5173/).
#pragma once

#define PG_WIFI_SSID      "your-wifi-ssid"
#define PG_WIFI_PASSWORD  "your-wifi-password"

// Backend HTTP base. NO trailing slash.
#define PG_SERVER_HOST    "192.168.1.42"
#define PG_SERVER_PORT    4000
