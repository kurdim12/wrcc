{
  "name": "palm-guard-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node --no-warnings=ExperimentalWarning --env-file-if-exists=.env server.js",
    "dev":   "node --no-warnings=ExperimentalWarning --env-file-if-exists=.env --watch server.js",
    "seed:farm": "node --no-warnings=ExperimentalWarning --env-file-if-exists=.env scripts/seedFarm.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "node-cron": "^3.0.3",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  }
}
