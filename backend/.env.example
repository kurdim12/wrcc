# Copy this file to backend/.env (gitignored) and fill in your OpenRouter key.
# Without this the AI Assistant chat will return 502 - everything else still works.
#
# Get a key at https://openrouter.ai/keys

PG_OPENROUTER_KEY=sk-or-v1-...

# Model. Recommended: anthropic/claude-3.5-sonnet (paid, best quality)
#                    deepseek/deepseek-chat            (paid, ~10x cheaper)
#                    meta-llama/llama-3.3-70b-instruct:free  (free tier, slower)
PG_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
PG_OPENROUTER_MAX_TOKENS=1024
