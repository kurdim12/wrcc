# Copy this file to backend/.env (gitignored) to override defaults.
# All values are optional — the backend runs fully without an .env.

# Server
# PORT=4000
# HOST=0.0.0.0

# SQLite path (defaults to backend/data/palmguard.db)
# PG_DB_PATH=./data/palmguard.db

# ML scoring service (optional; backend falls back to its own heuristic if down)
# PG_ML_URL=http://localhost:8001
